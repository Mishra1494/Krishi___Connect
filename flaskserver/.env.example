# Copy this file to .env and fill in the values.
# DO NOT commit your real .env file with secret keys to version control.

# ── GROQ API (Required) ──────────────────────────────────────
# Used for: Whisper STT + LLaMA-3.3 LLM (both via Groq)
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.ai/v1

# ── Google Cloud (Optional — better Marathi/Hindi STT accuracy) ──
# If set, will be used instead of Groq Whisper for STT.
# Set to path of your Google Cloud service account JSON file.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# ── OpenAI Whisper (Optional fallback) ──────────────────────
# Alternative to Groq Whisper. $0.006/min, no free tier.
# OPENAI_API_KEY=your_openai_key_here

# ── Flask Server Config ──────────────────────────────────────
FLASK_PORT=5002
FLASK_HOST=localhost
FLASK_DEBUG=false
